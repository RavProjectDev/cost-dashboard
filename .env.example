# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cost_dashboard"

# OpenAI API key (optional — adapter falls back to mock data if omitted)
OPENAI_API_KEY=""

# GCP project ID (the project that owns the BigQuery billing dataset)
GCP_PROJECT_ID="ravlegacyproject"

# Full BigQuery table reference for the billing export
GCP_BILLING_TABLE="ravlegacyproject.cost_table.gcp_billing_export_v1_010348_587C19_53C62D"

# Service account key JSON (production/CI only).
# For local dev, leave empty and run: gcloud auth application-default login
GCP_SERVICE_ACCOUNT_KEY=""
